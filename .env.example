# ============================================
# Prata Z Joias — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.

# --- Supabase ---
SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Bling ERP (API v3) ---
# Gere sua API Key em: https://www.bling.com.br/config/api
BLING_API_KEY=""

# --- Super Frete ---
# Gere seu token em: https://www.superfrete.com/para-empresas/token
SUPERFRETE_TOKEN=""

# --- Nubank / NuPay Business ---
# Gere suas credenciais no painel NuPay: https://www.nubank.com.br/para-empresas/
NUPAY_API_KEY=""
NUPAY_API_TOKEN=""

# --- Configurações Gerais ---
# CEP de origem da loja (formato: 00000-000)
STORE_CEP="64000-000"

# URL do site (usada para callbacks do Nubank)
SITE_URL="https://pratazjoias.com.br"
